# =====================================================================
# bugbot — deployment env (copy to deploy/.env, fill in, NEVER commit).
# All app settings are prefixed BUGBOT_. Tokens/secrets are never logged.
# =====================================================================

# ============================================================
# LLM backend — codex exec (default) or claude -p (fallback)
# ============================================================
# Primary backend: `codex` (default) or `claude`.
BUGBOT_LLM_BACKEND=codex

# Optional failover backend. When the PRIMARY returns ANY error other than a
# timeout (usage/quota exhausted, CLI error, unsupported mode, …), the request
# is retried on this backend. Unset = no failover (single backend).
#
# Example — prefer Claude, fall back to codex when Claude's usage is exhausted:
#   BUGBOT_LLM_BACKEND=claude
#   BUGBOT_LLM_FALLBACK_BACKEND=codex
# (`@bugbot fix` is write mode, which Claude refuses by design → it fails over
#  to codex automatically. For failover you must provision auth for BOTH CLIs.)
#BUGBOT_LLM_FALLBACK_BACKEND=codex

# --- codex exec auth — pick ONE -------------------------------------
#   A. API key (pay-per-token):
# OPENAI_API_KEY=sk-...
#   B. Subscription (ChatGPT): run `codex login` on the host once, then
#      bind-mount ~/.codex into the container (see docker-compose.yml).
#      No env var needed; the CLI reads its token from /home/bugbot/.codex.

BUGBOT_CODEX_CLI_PATH=codex
# Leave unset to use codex's entitled default model. Or pin, e.g.:
# BUGBOT_CODEX_MODEL=gpt-5.5
# Reasoning effort: low | medium | high. Unset = codex default.
# BUGBOT_CODEX_REASONING_EFFORT=high
# codex calls can take minutes; give them room.
BUGBOT_CODEX_TIMEOUT_SECONDS=900

# --- claude -p (only used when BUGBOT_LLM_BACKEND=claude) ------------
#   A. ANTHROPIC_API_KEY=sk-ant-...   B. bind-mount ~/.claude (subscription)
BUGBOT_CLAUDE_CLI_PATH=claude
BUGBOT_CLAUDE_MODEL=sonnet
BUGBOT_CLAUDE_TIMEOUT_SECONDS=600
# Read-only tools only — Bash/Edit/Write are refused at the client boundary.
BUGBOT_CLAUDE_ALLOWED_TOOLS=Read,Grep,Glob

# ============================================================
# Bitbucket Cloud (optional — enable by setting the app password)
# ============================================================
# Token scopes: repository:read, pullrequest:read, pullrequest:write.
# With a Repository/Workspace Access Token leave USERNAME=x-token-auth;
# with an App Password set it to your Bitbucket username.
#BUGBOT_BITBUCKET_USERNAME=x-token-auth
#BUGBOT_BITBUCKET_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
# BITBUCKET_TOKEN=xxxxxxxxxxxxxxxxxxxx   # alias, picked up automatically

# ============================================================
# GitHub (optional — enable with EITHER a GitHub App (preferred) or a PAT)
# ============================================================
# --- Option A: GitHub App (preferred) -------------------------------
# Own `my-app[bot]` identity + short-lived auto-rotating installation tokens.
# Create at Settings → Developer settings → GitHub Apps → New. Grant:
#   Repository permissions: Contents R&W (R-only if no @bugbot fix),
#                           Issues R&W, Pull requests R&W, Metadata R (implicit).
#                           (Issues R&W is required for the Issue comment event.)
#   Subscribe to events: Pull request, Issue comment, Pull request review comment.
# Then generate a private key (.pem), note the numeric App ID, and install it.
#BUGBOT_GITHUB_APP_ID=123456
# Inline PEM (literal \n between lines is accepted) …
#BUGBOT_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# … or (cleaner for Docker) bind-mount the .pem read-only and point at it:
#BUGBOT_GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app.pem
# REQUIRED with App auth + interactivity: installation tokens can't call
# GET /user, so set the bot login explicitly (your App slug + "[bot]").
#BUGBOT_GITHUB_BOT_LOGIN=my-app[bot]

# --- Option B: Personal Access Token (fallback) ---------------------
# Used only when the App above is NOT configured. Fine-grained PAT perms:
#   Contents: Read & write  (read for review; write for the autofix push)
#   Pull requests: Read & write
#   Metadata: Read (implicit)
# (Contents: Read only is fine if you don't use @bugbot fix.)
#BUGBOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=...   # alias
# With a PAT, BUGBOT_GITHUB_BOT_LOGIN is auto-detected via GET /user when unset.
#BUGBOT_GITHUB_BOT_LOGIN=my-bot-user

# Webhook secret — never shared with Bitbucket. `openssl rand -hex 32`.
# Used by both auth modes (the App's webhook secret goes here too).
#BUGBOT_GITHUB_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32
#BUGBOT_GITHUB_WEBHOOK_PATH=/webhook/github

# ============================================================
# git clone sandbox
# ============================================================
BUGBOT_GIT_CLONE_DEPTH=50
BUGBOT_GIT_CLONE_MAX_MB=512

# ============================================================
# Webhook server
# ============================================================
# Bitbucket webhook secret (required iff Bitbucket enabled). `openssl rand -hex 32`.
#BUGBOT_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32
BUGBOT_SERVER_HOST=0.0.0.0
BUGBOT_SERVER_PORT=8080
BUGBOT_WEBHOOK_PATH=/webhook/bitbucket
# Reject webhooks from non-Atlassian / non-GitHub source IPs.
BUGBOT_WEBHOOK_ENFORCE_IP_ALLOWLIST=true
BUGBOT_WEBHOOK_IP_CACHE_SECONDS=3600
# Caddy sits in front and sets X-Forwarded-For — trust it.
BUGBOT_TRUST_FORWARDED_FOR=true
# Each concurrent review/interaction owns one clone + one CLI subprocess.
BUGBOT_MAX_CONCURRENT_REVIEWS=2

# ============================================================
# Review behaviour
# ============================================================
BUGBOT_MAX_INLINE_COMMENTS=20
BUGBOT_MAX_DIFF_CHARS=120000
BUGBOT_IGNORE_GLOBS=*.lock,*.min.js,*.map,vendor/**,node_modules/**,dist/**,build/**
BUGBOT_DRY_RUN=false
BUGBOT_LOG_LEVEL=INFO
# Log timestamp offset from UTC in hours (e.g. 7 = UTC+7 / Asia/Bangkok). Default 0 = UTC.
#BUGBOT_LOG_UTC_OFFSET_HOURS=7
# Focus domain when a webhook hits a bare path. Available: general | data-eng | asr.
#BUGBOT_DEFAULT_DOMAIN=general

# ============================================================
# GitHub interactivity (Q&A + commands + fixes)
# ============================================================
# Respond to issue_comment / pull_request_review_comment events:
#   - reply to a bugbot comment, or `@bugbot <question>` → in-thread answer
#   - `@bugbot review` / `bugbot run` / `cursor review`   → re-review
#   - `@bugbot fix <instruction>`                          → apply a fix
#   - `@bugbot help`
BUGBOT_INTERACTIVE_ENABLED=true
# Allow `@bugbot fix` to run codex in workspace-write mode and push.
BUGBOT_FIX_ENABLED=true
# Loop guard: max autofix attempts per PR per 24h.
BUGBOT_FIX_MAX_PER_PR_24H=3
# Where fixes land: new-branch (opens a fix PR, recommended) | existing-branch.
BUGBOT_FIX_BRANCH_STRATEGY=new-branch

# NOTE: to receive interactive events, add these to the GitHub webhook's
# event list (in addition to "Pull requests"):
#   - Issue comments
#   - Pull request review comments
