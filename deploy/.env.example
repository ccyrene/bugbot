# =====================================================================
# bugbot — deployment env vars (Digital Ocean droplet / any Docker host)
# Copy to deploy/.env and fill in. NEVER commit .env.
# =====================================================================

# ============================================================
# Claude CLI auth — pick ONE of the two paths below.
# ============================================================

# --- Path A: API key (pay-per-token) ---------------------------------
# Comment out completely if you use Path B.
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Path B: Subscription (Claude Pro/Max) ---------------------------
# On your local machine: install Claude Code CLI, run `claude login`
# once, then bind-mount that directory into the container by un-
# commenting the `claude` volume line in docker-compose.yml:
#     - /root/.claude:/home/bugbot/.claude:ro
# No env var is needed for this path; the CLI reads its token from
# /home/bugbot/.claude/.

# ============================================================
# Claude run-time tuning
# ============================================================
BUGBOT_CLAUDE_CLI_PATH=claude
BUGBOT_CLAUDE_MODEL=sonnet
# Reasoning effort. One of: low | medium | high | xhigh | max.
# `high` is the recommended default for code review.
BUGBOT_CLAUDE_EFFORT=high
BUGBOT_CLAUDE_TIMEOUT_SECONDS=600

# Tools we let the model use inside the cloned PR working tree.
# Read-only by design — DO NOT add Bash/Edit/Write here.
BUGBOT_CLAUDE_ALLOWED_TOOLS=Read,Grep,Glob

# ============================================================
# Bitbucket Cloud
# ============================================================
# Required scopes on the token: repository:read, pullrequest:read,
# pullrequest:write. Same credentials are used for REST + git clone.
#
# If you use a Repository / Workspace Access Token, leave USERNAME at its
# default (`x-token-auth`). If you use an App Password, set USERNAME to
# your Bitbucket username instead.
#BUGBOT_BITBUCKET_USERNAME=x-token-auth
# Canonical name; the shorter `BITBUCKET_TOKEN` env is also accepted.
BUGBOT_BITBUCKET_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
# BITBUCKET_TOKEN=xxxxxxxxxxxxxxxxxxxx   # alias — picked up automatically

# Cap clone depth to keep tmpfs usage predictable.
BUGBOT_GIT_CLONE_DEPTH=50
# Reject repos whose .git directory grows past this size (MB) during clone.
BUGBOT_GIT_CLONE_MAX_MB=512

# ============================================================
# Webhook server
# ============================================================
# Shared secret you'll paste into Bitbucket's webhook config. Must match
# byte-for-byte. Generate with: `openssl rand -hex 32`
BUGBOT_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

BUGBOT_SERVER_HOST=0.0.0.0
BUGBOT_SERVER_PORT=8080
BUGBOT_WEBHOOK_PATH=/webhook/bitbucket

# Reject webhooks from non-Atlassian IPs.
BUGBOT_WEBHOOK_ENFORCE_IP_ALLOWLIST=true
BUGBOT_WEBHOOK_IP_CACHE_SECONDS=3600

# Trust X-Forwarded-For only because Caddy is in front. Leave as-is.
BUGBOT_TRUST_FORWARDED_FOR=true

# Each concurrent review owns one clone + one `claude` subprocess.
BUGBOT_MAX_CONCURRENT_REVIEWS=2

# ============================================================
# Review behaviour
# ============================================================
BUGBOT_MAX_INLINE_COMMENTS=20
BUGBOT_MAX_DIFF_CHARS=120000
BUGBOT_IGNORE_GLOBS=*.lock,*.min.js,*.map,vendor/**,node_modules/**,dist/**,build/**
BUGBOT_DRY_RUN=false
BUGBOT_LOG_LEVEL=INFO
